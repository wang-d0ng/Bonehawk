# Robinhood Crypto Trading API
# Create these in Robinhood web classic crypto account settings.
ROBINHOOD_API_KEY=
ROBINHOOD_PRIVATE_KEY_BASE64=
ROBINHOOD_ACCOUNT_NUMBER=
ROBINHOOD_API_VERSION=v2

# Robinhood Agentic Trading MCP for stocks
ROBINHOOD_AGENTIC_MCP_URL=https://agent.robinhood.com/mcp/trading
BONEHAWK_STOCK_TRADING_MODE=review
# disabled keeps Buy/Sell buttons review-only. Use codex_mcp only after MCP login and paper testing.
BONEHAWK_STOCK_ORDER_CONNECTOR=disabled
BONEHAWK_STOCK_ORDER_TIMEOUT_SEC=180
BONEHAWK_UI_THEME=arcade
BONEHAWK_SETUP_COMPLETE=false

# Alpaca stock/crypto trading API
# Start with paper keys from Alpaca. Do not enable live until paper flow is tested.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_ALLOW_LIVE=false
ALPACA_TIMEOUT_SEC=20

# Trading mode guard. Keep paper until you are ready for live order placement.
TRADING_MODE=paper

# Telegram notifications
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_IDS=
