# Bonehawk UI
BONEHAWK_UI_THEME=arcade
BONEHAWK_SETUP_COMPLETE=false

# Alpaca stock/crypto trading API
# Start with paper keys from Alpaca. Do not enable live until paper flow is tested.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_ALLOW_LIVE=false
ALPACA_TIMEOUT_SEC=20

# Trading mode guard. Keep paper until you are ready for live order placement.
TRADING_MODE=paper

# Optional passive research feeds
# Reddit RSS is off by default because full-market scans can make many requests.
BONEHAWK_REDDIT_RSS=false
# X/Twitter requires an allowed RSS/API bridge you control, for example:
# BONEHAWK_X_RSS_TEMPLATE=https://example.com/search.rss?q={symbol}
BONEHAWK_X_RSS_TEMPLATE=
# JSON list of extra feed templates: [{"source":"stocktwits","url":"https://example.com/{raw_symbol}.rss"}]
BONEHAWK_SOCIAL_RSS_TEMPLATES=

# Telegram notifications
TELEGRAM_BOT_TOKEN=
ALLOWED_CHAT_IDS=
